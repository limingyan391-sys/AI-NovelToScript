{
  "ai_providers": {
    "openai": {
      "name": "OpenAI",
      "endpoint": "https://api.openai.com/v1",
      "models": [
        "gpt-4o",
        "gpt-4o-mini",
        "gpt-4-turbo"
      ],
      "default_model": "gpt-4o",
      "env_var": "OPENAI_API_KEY"
    },
    "deepseek": {
      "name": "DeepSeek",
      "endpoint": "https://api.deepseek.com/v1",
      "models": [
        "deepseek-chat",
        "deepseek-reasoner"
      ],
      "default_model": "deepseek-chat",
      "env_var": "DEEPSEEK_API_KEY"
    },
    "custom": {
      "name": "???",
      "endpoint": "",
      "models": [],
      "default_model": "",
      "env_var": ""
    }
  }
}